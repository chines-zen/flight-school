PORT=8080
NODE_ENV=development

# PostgreSQL connection
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_NAME=flight_school
DB_PORT=5432

# Used for session signing and Airtable PAT encryption. Use a long random value in production.
APP_SECRET=replace-with-at-least-32-random-characters

# Optional local development identity fallback.
# In development, you can also use ?devEmail=user@zendesk.com or X-Dev-Email.
DEV_EMAIL=chines@zendesk.com

# Google Gemini API key, required for the AI Readiness > Knowledge Assessment module.
# Create one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override the Gemini model (default: gemini-2.0-flash).
GEMINI_MODEL=gemini-2.0-flash
# Optional: tune how many Help Center articles are scanned/analyzed per run.
KB_MAX_ARTICLES_SCANNED=300
KB_MAX_ARTICLES_ANALYZED=12
